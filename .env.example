# ============================================
# Suntech Systems - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Email (Contact Form via Nodemailer) ──────────────────
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_TO=your_receiving_email@gmail.com

# ── Company Info (Displayed on site & in chatbot) ────────
NEXT_PUBLIC_COMPANY_PHONE=your_company_phone_number
NEXT_PUBLIC_COMPANY_EMAIL=your_company_email@gmail.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── OpenRouter AI (SolarGPT Chatbot) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-2.5-flash-preview-09-2025

# ── Supabase (Dynamic Calculator Data) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ── Cron / Test Auth (Scraper endpoints) ─────────────────
TEST_PASSWORD=change_this_to_a_strong_password
CRON_SECRET=change_this_to_a_strong_secret
